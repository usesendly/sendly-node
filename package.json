{
  "name": "@sendlyapp/sdk",
  "version": "0.1.1",
  "description": "Node.js SDK for the Sendly API",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "tsdown": "^0.21.9"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
